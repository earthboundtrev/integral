{
  "id": "strong-medicine",
  "name": "Strong Medicine",
  "author": "Chris Hardy & Marty Gallagher",
  "source": "Strong Medicine: How to Conquer Chronic Disease and Achieve Your Full Genetic Potential (2015)",
  "program_type": "reference",
  "description": "Resistance foundation (squat, sumo deadlift, bench, overhead press, row, anti-sit-up core) plus Burst Cardio HIIT. Foreword by Paul Wade. Pause-at-bottom grind technique; make light weights heavy.",
  "progression_model": "step_ladder",
  "notation": "Master technique before load — 3×6–10 typical working sets when programming",
  "reference_sections": [
    {
      "id": "sm-burst-cardio",
      "name": "Burst Cardio (HIIT)",
      "summary": "Alternate 90–95% HRmax bursts with recovery to ~70% HRmax. Sessions 10–20 min. Use HR monitor; switch modality if you cannot hit 90% HRmax."
    },
    {
      "id": "sm-weekly-template",
      "name": "Sample Weekly Template",
      "summary": "Mon: Squat superset + walk. Tue: Burst cardio. Wed: Bench superset Row. Thu: rest/walk. Fri: Sumo deadlift. Sat/Sun: burst cardio or rest. See Battle Plan III for 12-week wave."
    }
  ],
